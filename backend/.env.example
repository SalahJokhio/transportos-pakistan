# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=Transport OS
APP_URL=http://localhost:3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=transport_os
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# Read Replicas (for scaling)
DATABASE_READ_HOST_1=localhost
DATABASE_READ_PORT_1=5433

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Cluster (for production)
REDIS_CLUSTER_NODES=localhost:6379,localhost:6380,localhost:6381

# ============================================================================
# JWT
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# OAUTH
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ============================================================================
# AWS
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=transport-os-files

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================
# Switch every gateway between sandbox and live with ONE flag. Endpoints are
# resolved automatically per mode in payment.config.ts — no code change to go live.
# Leave the credentials as "your-..." to keep a provider in mock/sandbox mode;
# fill in the real values (from the JazzCash/EasyPaisa merchant portal) to go live.
PAYMENT_MODE=sandbox   # sandbox | production

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# JazzCash (get these from the JazzCash merchant portal when the account is live)
JAZZCASH_MERCHANT_ID=your-merchant-id
JAZZCASH_PASSWORD=your-password
JAZZCASH_INTEGRITY_SALT=your-integrity-salt
JAZZCASH_RETURN_URL=http://localhost:3000/api/v1/payments/jazzcash/callback

# EasyPaisa (Telenor Microfinance merchant portal)
EASYPAISA_STORE_ID=your-store-id
EASYPAISA_PASSWORD=your-password
EASYPAISA_HASH_KEY=your-hash-key
EASYPAISA_ACCOUNT_NUM=your-merchant-account
EASYPAISA_RETURN_URL=http://localhost:3000/api/v1/payments/easypaisa/callback

# ============================================================================
# GOOGLE MAPS
# ============================================================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@transportos.com
SENDGRID_FROM_NAME=Transport OS

# WhatsApp Business API
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-project-id

# ============================================================================
# MESSAGE QUEUE (Bull/Redis)
# ============================================================================
QUEUE_HOST=localhost
QUEUE_PORT=6379

# ============================================================================
# ELASTICSEARCH
# ============================================================================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ============================================================================
# MONITORING
# ============================================================================
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# ============================================================================
# RATE LIMITING
# ============================================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================================
# CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ============================================================================
# WEBSOCKET
# ============================================================================
WEBSOCKET_PORT=3001

# ============================================================================
# MICROSERVICES PORTS
# ============================================================================
API_GATEWAY_PORT=3000
BOOKING_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
FLEET_SERVICE_PORT=3004
TRACKING_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
AI_SERVICE_PORT=3008
USER_SERVICE_PORT=3009